{
  "name": "@realtalk-ai/react",
  "version": "0.1.0",
  "description": "React hooks for Real Talk voice and text conversations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@realtalk-ai/core": "^0.1.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@realtalk-ai/core": "^0.1.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^28.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "license": "MIT"
}
